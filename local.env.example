# Copy this to local.env and fill in your paths.

# Quantization
MODEL_CHECKPOINT = "/path/to/chandra"
OUTPUT_PATH_FP8  = "/path/to/chandra-fp8"
OUTPUT_PATH_INT4 = "/path/to/chandra-int4"
CALIBRATION_PATH = "/path/to/calibration_data"
NUM_CAL_SAMPLES  = 512
MAX_SEQ_LEN      = 2048

# Serving
SERVE_HOST    = localhost
SERVE_PORT    = 8000
MAX_MODEL_LEN = 8192
GPU_MEM_UTIL  = 0.85
GPU_INDEX     = 0
OCR_PROMPT    = Extract all text from this document.
